---
import BaseLayout from '../layouts/BaseLayout.astro';

const pageTitle = "About Me";

const identity = {
  firstName: "Elly",
  country: "Kenya",
  occupation: "Computer science student",
  hobbies: ["playing soccer", "listening to music", "partying with friends", "watching movies", "reading books"],
};

const skills = ["HTML", "CSS", "JavaScript", "React", "Astro", "Writing Docs"];

const happy = true;
const finished = false;
const goal = 3;

const skillColor = "navy";
const fontWeight = "bold";
const textCase = "uppercase";
---

<BaseLayout pageTitle={pageTitle}>
  <style is:global define:vars={{skillColor, fontWeight, textCase}}>
    h1 {
      color: purple;
      font-size: 3rem;
    }
    .skill {
      color: var(--skillColor);
      font-weight: var(--fontWeight);
      text-transform: var(--textCase);
    }
    body { font-family: sans-serif; max-width: 800px; margin: 2rem auto; padding: 0 1rem; line-height: 1.6; }
    nav { display: flex; flex-direction: column; gap: 0.5rem; margin-bottom: 2rem; border-bottom: 1px solid #ccc; padding-bottom: 1rem; }
    nav a { text-decoration: none; color: navy; font-weight: bold; }
  </style>

  <section>
    <h2>Who am I?</h2>
    <p>Hello! My name is <strong>{identity.firstName}</strong>. I am based in {identity.country} and I am currently working as a {identity.occupation}.</p>
  </section>

  <section>
    <h2>My Hobbies</h2>
    <p>In my free time, I enjoy:</p>
    <ul>
      {identity.hobbies.map((hobby) => <li>{hobby}</li>)}
    </ul>
  </section>

  <section>
    <h2>My Technical Skills</h2>
    <ul>
      {skills.map((skill) => <li class="skill">{skill}</li>)}
    </ul>
  </section>

  {happy && <p>✨ I am happy to be learning Astro!</p>}
  {finished && <p>✅ I finished this tutorial!</p>}

  <section>
    <h3>My Progress Goal</h3>
    {goal === 3 ? <p>My goal is to finish this tutorial in 3 days.</p> : <p>My goal is not 3 days.</p>}
  </section>
</BaseLayout>