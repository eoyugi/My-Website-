---
const pageTitle = "Home Page";
---
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{pageTitle}</title>
  </head>
  <body>
    <nav>
      <a href="/">Home</a>
      <a href="/about/">About</a>
      <a href="/blog/">Blog</a>
    </nav>

    <main>
      <h1>{pageTitle}</h1>
      <p>Welcome to my website!</p>
    </main>
  </body>
</html>

<style>
  body {
    font-family: sans-serif;
    line-height: 1.6;
    max-width: 800px;
    margin: 0 auto; /* Centers the site */
    padding: 2rem;
    color: #333;
  }
  nav {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
    border-bottom: 1px solid #eee;
    padding-bottom: 1rem;
  }
  nav a {
    text-decoration: none;
    color: #007bff;
    font-weight: bold;
  }
</style>